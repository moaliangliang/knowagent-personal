{
  "name": "zhixing",
  "version": "1.1.0",
  "description": "\u77e5\u884c (ZhiXing) \u2014 AI-powered macOS desktop automation assistant",
  "author": "ZhiXing Team <team@zhixing.ai>",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:mas": "electron-builder --config.afterSign=scripts/notarize.mas.js --mac=mas",
    "dist:mas-dev": "electron-builder --config.afterSign=scripts/notarize.mas.js --mac=mas-dev",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "notarize": "node scripts/notarize.js",
    "build:all": "npm run dist:mac && npm run dist:mas"
  },
  "build": {
    "appId": "com.zhixing.desktop",
    "productName": "ZhiXing",
    "copyright": "Copyright \u00a9 2026 ZhiXing Team",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "sync.js",
      "renderer/**/*",
      "package.json"
    ],
    "npmRebuild": false,
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "icon": "build/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.inherit.plist",
      "minimumSystemVersion": "11.0",
      "notarize": false,
      "identity": "Apple Distribution: liangliang mao (Y3K9Z836YN)"
    },
    "mas": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "mas-dev",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "mas",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "entitlements": "entitlements.mas.plist",
      "entitlementsInherit": "entitlements.mas.inherit.plist",
      "minimumSystemVersion": "11.0",
      "hardenedRuntime": false,
      "identity": "Apple Distribution: liangliang mao (Y3K9Z836YN)"
    },
    "dmg": {
      "title": "ZhiXing ${version}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 440
      }
    },
    "pkg": {
      "scripts": "scripts/pkg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Utility"
    }
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-notarize": "^1.2.2",
    "electron-updater": "^6.0.0"
  }
}